NODE_ENV=development
PORT=3000

DATABASE_URL="postgresql://jobtrack:jobtrack@localhost:5433/jobtrack?schema=public"

# Single URL for managed Redis (Coolify/Upstash/Railway). Carries credentials + TLS.
# rediss:// = TLS. Takes precedence over REDIS_HOST/REDIS_PORT when set.
# REDIS_URL=rediss://default:password@redis-host:6379/0
REDIS_HOST=localhost
REDIS_PORT=6380

JWT_ACCESS_SECRET=replace-me-min-32-chars-xxxxxxxxxxxxx
JWT_REFRESH_SECRET=replace-me-min-32-chars-yyyyyyyyyyyy
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Optional: create an ADMIN user when seeding. Omit to skip admin creation.
SEED_ADMIN_PASSWORD=
